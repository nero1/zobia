{
  "name": "zobia-social",
  "version": "1.0.0",
  "private": true,
  "description": "Zobia Social — Gamified Monetised Social Platform",
  "workspaces": [
    "apps/web",
    "apps/expo",
    "shared"
  ],
  "scripts": {
    "dev:web": "cd apps/web && npm run dev",
    "dev:expo": "cd apps/expo && npx expo start",
    "build:web": "cd apps/web && npm run build",
    "build:expo": "cd apps/expo && eas build --platform android",
    "migrate": "cd apps/web && npx tsx db/migrate.ts",
    "seed": "cd apps/web && npx tsx db/seed.ts",
    "lint": "npm run lint --workspaces",
    "typecheck": "npm run typecheck --workspaces"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
