{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "node": "20.19.4",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug",
        "env": {
          "APP_ENV": "development",
          "API_BASE_URL": "https://zobia.vercel.app",
          "EAS_PROJECT_ID": "$EAS_PROJECT_ID"
        }
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "node": "20.19.4",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease",
        "env": {
          "APP_ENV": "preview",
          "API_BASE_URL": "https://zobia.vercel.app",
          "EAS_PROJECT_ID": "$EAS_PROJECT_ID"
        }
      }
    },
    "staging": {
      "distribution": "internal",
      "channel": "staging",
      "node": "20.19.4",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease",
        "env": {
          "APP_ENV": "staging",
          "API_BASE_URL": "https://zobia.vercel.app",
          "EAS_PROJECT_ID": "$EAS_PROJECT_ID"
        }
      }
    },
    "production": {
      "distribution": "store",
      "channel": "production",
      "node": "20.19.4",
      "android": {
        "buildType": "app-bundle",
        "gradleCommand": ":app:bundleRelease",
        "env": {
          "APP_ENV": "production",
          "API_BASE_URL": "https://zobia.vercel.app",
          "ADMOB_APP_ID_ANDROID": "$ADMOB_APP_ID_ANDROID",
          "ADMOB_APP_ID_IOS": "$ADMOB_APP_ID_IOS",
          "EXPO_PUBLIC_ADMOB_REWARDED_ANDROID": "$EXPO_PUBLIC_ADMOB_REWARDED_ANDROID",
          "EXPO_PUBLIC_ADMOB_BANNER_ANDROID": "$EXPO_PUBLIC_ADMOB_BANNER_ANDROID",
          "EXPO_PUBLIC_ADMOB_INTERSTITIAL_ANDROID": "$EXPO_PUBLIC_ADMOB_INTERSTITIAL_ANDROID",
          "EAS_PROJECT_ID": "$EAS_PROJECT_ID"
        }
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "production"
      }
    }
  }
}
