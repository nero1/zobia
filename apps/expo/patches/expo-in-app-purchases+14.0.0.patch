+// expo-in-app-purchases 14.0.0 targets Play Billing 4.x and uses SKU-based APIs
+// (SkuDetails, querySkuDetailsAsync, setVrPurchaseFlow, Purchase.getSkus) that were
+// removed in Billing 5.0+. When another dependency pulls a newer Billing version onto
+// the classpath, Gradle conflict-resolves billing upward and this module fails to
+// compile (compileReleaseJavaWithJavac: cannot find symbol). Pin Billing to 4.0.0 so
+// the module compiles while the app keeps compileSdkVersion / targetSdkVersion 36.
+configurations.all {
+  resolutionStrategy {
+    force 'com.android.billingclient:billing:4.0.0'
+  }
+}
