{
  "expo": {
    "name": "Zobia Social",
    "slug": "zobia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "zobia",
    "runtimeVersion": "1.0.0",
    "updates": {
      "enabled": false
    },
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "org.zobia.social",
      "associatedDomains": [
        "applinks:zobia.vercel.app",
        "applinks:www.zobia.vercel.app"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "googleServicesFile": "./google-services.json",
      "package": "org.zobia.social",
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.READ_CONTACTS"
      ],
      "softwareKeyboardLayoutMode": "adjustResize",
      "allowBackup": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "zobia.vercel.app",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "www.zobia.vercel.app",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-notifications",
      "expo-contacts",
      "expo-router",
      "expo-secure-store",
      "expo-localization",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "buildToolsVersion": "35.0.0",
            "kotlinVersion": "1.9.23"
          }
        }
      ],
      "expo-updates",
      [
        "./plugins/withGoogleMobileAds",
        {
          "android_app_id": "ca-app-pub-3940256099942544~3347511713",
          "ios_app_id": "ca-app-pub-3940256099942544~1458002511"
        }
      ],
      "./plugins/withIapPlayFlavor",
      "./plugins/withKotlinFix"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": "https://zobia.vercel.app"
      },
      "API_BASE_URL": "https://zobia.vercel.app",
      "WEB_BASE_URL": "https://zobia.vercel.app",
      "telegramBotName": "Zobia_bot_bot",
      "eas": {
        "projectId": "406a3077-0565-4a71-9c86-149a95396cc7"
      }
    }
  }
}
