{
  "expo": {
    "name": "Zobia Social",
    "slug": "zobia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "zobia",
    "entryPoint": "expo-router/entry",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "org.zobia.social",
      "associatedDomains": [
        "applinks:zobia.vercel.app",
        "applinks:www.zobia.vercel.app"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "googleServicesFile": "./google-services.json",
      "package": "org.zobia.social",
      "compileSdkVersion": 36,
      "targetSdkVersion": 36,
      "minSdkVersion": 24,
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.READ_CONTACTS"
      ],
      "softwareKeyboardLayoutMode": "adjustResize",
      "allowBackup": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "zobia.vercel.app",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "www.zobia.vercel.app",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-notifications",
      "expo-contacts",
      "expo-router",
      "expo-secure-store",
      "expo-localization",
      [
        "expo-updates",
        {
          "projectId": "ad68e531-aa48-4873-8d41-3bca8f18b9a4",
          "runtimeVersion": { "policy": "fingerprint" }
        }
      ],
      "./plugins/withGoogleMobileAds",
      "./plugins/withIapPlayFlavor"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": "https://zobia.vercel.app"
      },
      "API_BASE_URL": "https://zobia.vercel.app",
      "WEB_BASE_URL": "https://zobia.vercel.app",
      "telegramBotName": "Zobia_bot_bot",
      "eas": {
        "projectId": "ad68e531-aa48-4873-8d41-3bca8f18b9a4"
      }
    }
  }
}
