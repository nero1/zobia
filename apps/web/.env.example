# =============================================================================
# Zobia Social – Web App Environment Variables
# Copy this file to .env.local and fill in all values.
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------

# Which database provider to use: supabase | railway | digitalocean
DATABASE_PROVIDER=supabase

# Primary connection string (used by app server)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Direct connection string (bypasses PgBouncer, used for migrations)
DIRECT_URL=postgresql://user:password@host:5432/dbname

# -----------------------------------------------------------------------------
# STORAGE
# -----------------------------------------------------------------------------

# Which storage provider to use: supabase-storage | r2 | s3
STORAGE_PROVIDER=supabase-storage

# Cloudflare R2 credentials (required when STORAGE_PROVIDER=r2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# -----------------------------------------------------------------------------
# REALTIME
# -----------------------------------------------------------------------------

# Which realtime provider to use: supabase-realtime | ably | pusher
REALTIME_PROVIDER=supabase-realtime

# -----------------------------------------------------------------------------
# REDIS
# -----------------------------------------------------------------------------

# Redis connection URL
REDIS_URL=redis://localhost:6379

# Which Redis client to use: ioredis | upstash
REDIS_PROVIDER=ioredis

# Upstash REST credentials (required when REDIS_PROVIDER=upstash)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# AUTH / JWT
# -----------------------------------------------------------------------------

# Secret for signing access tokens (min 32 characters, random)
JWT_SECRET=change-me-to-a-long-random-secret-value

# Secret for signing refresh tokens (different from JWT_SECRET)
JWT_REFRESH_SECRET=change-me-to-another-long-random-secret

# -----------------------------------------------------------------------------
# GOOGLE OAUTH
# -----------------------------------------------------------------------------

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# TELEGRAM LOGIN
# -----------------------------------------------------------------------------

TELEGRAM_BOT_TOKEN=

# -----------------------------------------------------------------------------
# AI PROVIDERS
# -----------------------------------------------------------------------------

# DeepSeek (primary AI provider)
DEEPSEEK_API_KEY=
DEEPSEEK_API_ENDPOINT=https://api.deepseek.com/v1

# Gemini (fallback AI provider)
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# EMAIL
# -----------------------------------------------------------------------------

MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.yourdomain.com

# -----------------------------------------------------------------------------
# PAYMENTS
# -----------------------------------------------------------------------------

# Paystack (Africa-first payments)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# DodoPayments (global)
DODOPAYMENTS_API_KEY=

# -----------------------------------------------------------------------------
# ADVERTISING
# -----------------------------------------------------------------------------

ADMOB_APP_ID=

# -----------------------------------------------------------------------------
# BOT PROTECTION
# -----------------------------------------------------------------------------

# Google reCAPTCHA v3
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Cloudflare Turnstile (preferred over reCAPTCHA)
CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# -----------------------------------------------------------------------------
# PUBLIC / CLIENT-SIDE VARS  (exposed to the browser via NEXT_PUBLIC_ prefix)
# -----------------------------------------------------------------------------

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api
