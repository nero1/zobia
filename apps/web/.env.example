# =============================================================================
# Zobia Social – Web App Environment Variables
# Copy this file to .env.local and fill in all values.
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------

# Which database provider to use: supabase | railway | digitalocean
DATABASE_PROVIDER=supabase

# Primary connection string (used by app server — pooler transaction mode)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Direct connection string (bypasses PgBouncer, used for migrations)
DIRECT_URL=postgresql://user:password@host:5432/dbname

# -----------------------------------------------------------------------------
# STORAGE
# -----------------------------------------------------------------------------

# Which storage provider to use: supabase-storage | r2 | s3
STORAGE_PROVIDER=supabase-storage

# Cloudflare R2 credentials (required when STORAGE_PROVIDER=r2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# -----------------------------------------------------------------------------
# REALTIME
# -----------------------------------------------------------------------------

# Which realtime provider to use: supabase-realtime | ably | pusher
REALTIME_PROVIDER=supabase-realtime

# -----------------------------------------------------------------------------
# REDIS
# -----------------------------------------------------------------------------

# Redis connection URL
REDIS_URL=redis://localhost:6379

# Which Redis client to use: ioredis | upstash
REDIS_PROVIDER=ioredis

# Upstash REST credentials (required when REDIS_PROVIDER=upstash)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# AUTH / JWT
# -----------------------------------------------------------------------------

# Secret for signing access tokens (min 32 characters — use: openssl rand -hex 64)
JWT_SECRET=change-me-to-a-long-random-secret-value

# Secret for signing refresh tokens (different from JWT_SECRET)
JWT_REFRESH_SECRET=change-me-to-another-long-random-secret

# -----------------------------------------------------------------------------
# GOOGLE OAUTH
# -----------------------------------------------------------------------------

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# TELEGRAM
# -----------------------------------------------------------------------------

# Telegram bot token for Telegram Login (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Secret for authenticating incoming Telegram webhook requests
TELEGRAM_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# AI PROVIDERS
# -----------------------------------------------------------------------------

# DeepSeek (primary AI provider)
DEEPSEEK_API_KEY=
DEEPSEEK_API_ENDPOINT=https://api.deepseek.com/v1

# Gemini (fallback AI provider)
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# EMAIL
# -----------------------------------------------------------------------------

MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.yourdomain.com

# -----------------------------------------------------------------------------
# PAYMENTS
# -----------------------------------------------------------------------------

# Paystack (Africa-first payments) — ensure Transfers permission is enabled
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# DodoPayments (global)
DODOPAYMENTS_API_KEY=

# -----------------------------------------------------------------------------
# IN-APP PURCHASES
# -----------------------------------------------------------------------------

# Google Play service account JSON (base64-encoded or raw JSON string)
# Required for server-side IAP receipt verification on Android
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=

# -----------------------------------------------------------------------------
# ADVERTISING
# -----------------------------------------------------------------------------

ADMOB_APP_ID=

# -----------------------------------------------------------------------------
# BOT PROTECTION
# -----------------------------------------------------------------------------

# Google reCAPTCHA v3
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Cloudflare Turnstile (preferred over reCAPTCHA)
CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# -----------------------------------------------------------------------------
# CRON JOBS
# -----------------------------------------------------------------------------

# Shared secret for authenticating CRON endpoint requests (required in production)
# Generate with: openssl rand -hex 32
CRON_SECRET=

# -----------------------------------------------------------------------------
# SECURITY / ENCRYPTION
# -----------------------------------------------------------------------------

# AES encryption key for KYC field-level encryption (32-byte hex string)
# Generate with: openssl rand -hex 32
KYC_ENCRYPTION_KEY=

# Service-to-service authentication token (e.g. for the XP award endpoint)
# Defaults to JWT_SECRET if not set
SERVICE_TOKEN=

# -----------------------------------------------------------------------------
# GIF SEARCH
# -----------------------------------------------------------------------------

# Tenor GIF API key (optional — enables Tenor GIF search in messages)
TENOR_API_KEY=

# Giphy GIF API key (optional — fallback GIF search)
GIPHY_API_KEY=

# -----------------------------------------------------------------------------
# PUSH NOTIFICATIONS (Expo)
# -----------------------------------------------------------------------------

# Expo access token for enhanced push delivery (optional)
EXPO_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# MODERATION
# -----------------------------------------------------------------------------

# Comma-separated list of additional profanity words (optional)
PROFANITY_WORDLIST=

# -----------------------------------------------------------------------------
# PUBLIC / CLIENT-SIDE VARS  (exposed to the browser via NEXT_PUBLIC_ prefix)
# -----------------------------------------------------------------------------

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Set to "false" to disable PWA/service-worker generation at build time
NEXT_PUBLIC_PWA_WEB_ENABLED=true

# -----------------------------------------------------------------------------
# BUILD / RUNTIME
# -----------------------------------------------------------------------------

# Runtime environment (development | test | production) — set automatically by Next.js
# NODE_ENV=development

# Set to "1" to skip env-var Zod validation at build time (CI type-check only)
# SKIP_ENV_VALIDATION=1
